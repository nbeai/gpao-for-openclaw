{
  "name": "@nbeai/beai-runtime",
  "version": "0.6.22",
  "type": "module",
  "description": "BEAI Runtime v0.6.22 plugin component inside GPAO for OpenClaw: evidence-aware replies, Context Mesh continuity, Knowledge Loop review-first capture, Telegram delivery contracts, and flow-state judgment.",
  "files": [
    "dist/index.js",
    "dist/runtime-core.js",
    "runtime/beai-runtime-lib.cjs",
    "openclaw.plugin.json",
    "README.md",
    "README.dist.md",
    "RELEASE-NOTES-v0.6.22-ko.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.6"
    },
    "build": {
      "openclawVersion": "2026.6.10",
      "pluginSdkVersion": "2026.6.10"
    },
    "install": {
      "clawhubSpec": "@nbeai/beai-runtime",
      "minHostVersion": ">=2026.6.10",
      "defaultChoice": "clawhub"
    }
  },
  "product": "GPAO for OpenClaw",
  "componentOf": "GPAO for OpenClaw",
