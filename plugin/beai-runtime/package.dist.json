{
  "name": "@nbeai/beai-runtime",
  "version": "0.6.19",
  "type": "module",
  "description": "BEAI Layer v0.6.19 runtime plugin for OpenClaw. Dist-only clean public release candidate package.",
  "files": [
    "dist/index.js",
    "dist/runtime-core.js",
    "runtime/beai-runtime-lib.cjs",
    "openclaw.plugin.json",
    "README.md",
    "README.dist.md",
    "RELEASE-NOTES-v0.6.19-ko.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.6"
    },
    "build": {
      "openclawVersion": "2026.6.10",
      "pluginSdkVersion": "2026.6.10"
    },
    "install": {
      "clawhubSpec": "@nbeai/beai-runtime",
      "minHostVersion": ">=2026.6.10",
      "defaultChoice": "clawhub"
    }
  }
}
