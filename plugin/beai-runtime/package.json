{
  "name": "openclaw-plugin-beai-runtime",
  "version": "0.6.17",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plugin:build": "npm run build",
    "test": "node --check dist/index.js && node --check dist/runtime-core.js"
  },
