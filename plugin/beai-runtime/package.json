{
  "name": "@nbeai/beai-runtime",
  "version": "0.6.17",
  "type": "module",
  "description": "BEAI Layer runtime plugin for OpenClaw: evidence-aware replies, Knowledge Loop review-first capture, Telegram delivery contracts, and flow-state judgment.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plugin:build": "npm run build",
    "test": "node --check dist/index.js && node --check dist/runtime-core.js"
  },
  "files": [
    "dist/index.js",
    "dist/runtime-core.js",
    "runtime/beai-runtime-lib.cjs",
    "openclaw.plugin.json",
    "README.md",
    "README.dist.md",
    "RELEASE-NOTES-v0.6.17-ko.md"
  ],
  "dependencies": {
    "openclaw": "2026.6.10"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.6"
    },
    "build": {
      "openclawVersion": "2026.6.10",
      "pluginSdkVersion": "2026.6.10"
    },
    "install": {
      "clawhubSpec": "@nbeai/beai-runtime",
      "minHostVersion": ">=2026.6.10",
      "defaultChoice": "clawhub"
    }
  }
}
