    "dist/index.js",
    "dist/runtime-core.js",
    "runtime/beai-runtime-lib.cjs",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "openclaw": "2026.6.9"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
