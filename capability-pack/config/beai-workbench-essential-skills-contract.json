      ],
      "outputs": [
        "source registry",
        "evidence matrix",
        "claim map",
        "counter-evidence brief",
        "decision source pack"
      ],
      "qualityGates": [
        "research"
      ]
    },
    {
      "id": "beai-data-insight-lab",
      "label": "BEAI Data Insight Lab",
      "domain": "data-insight",
      "source": "skills/beai-data-insight-lab/SKILL.md",
      "status": "source-candidate",
      "triggers": [
        "CSV",
        "XLSX",
        "spreadsheet analysis",
        "statistics",
        "chart",
        "data insight"
      ],
      "patterns": [
        "profile_dataset",
        "create_cleaning_log",
        "audit_formula_integrity",
        "choose_honest_chart",
        "separate_correlation_from_causation",
        "summarize_decision_implication",
        "build_reproducibility_notes",
        "stress_test_interpretation",
