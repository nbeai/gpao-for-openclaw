        "create_document_scaffold",
        "draft_section_with_options",
        "run_reader_test",
        "format_submission_version",
        "create_review_packet",
        "track_open_questions",
        "handoff_document_decisions"
      ],
      "outputs": [
        "document scaffold",
        "draft sections",
        "reader test",
        "submission candidate",
        "format notes"
      ],
      "qualityGates": [
        "document"
      ]
    },
    {
      "id": "beai-research-evidence-studio",
      "label": "BEAI Research Evidence Studio",
      "domain": "research-evidence",
      "source": "skills/beai-research-evidence-studio/SKILL.md",
      "status": "source-candidate",
      "triggers": [
        "research",
