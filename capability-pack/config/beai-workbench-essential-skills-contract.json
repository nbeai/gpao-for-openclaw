      ]
    },
    {
      "id": "beai-document-craft-studio",
      "label": "BEAI Document Craft Studio",
      "domain": "document-craft",
      "source": "skills/beai-document-craft-studio/SKILL.md",
      "status": "source-candidate",
      "triggers": [
        "proposal",
