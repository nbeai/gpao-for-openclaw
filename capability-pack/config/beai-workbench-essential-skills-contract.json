        "chart recommendation",
        "decision implication"
      ],
      "qualityGates": [
        "data"
      ]
    }
  ],
  "doctor_issue_codes": [
    "beai-workbench-contract-missing",
    "beai-workbench-skill-missing",
    "beai-workbench-skill-section-missing",
    "beai-workbench-quality-gate-missing",
