        "source pack"
      ],
      "patterns": [
        "build_source_registry",
        "separate_claim_fact_inference",
        "check_recency",
        "find_counter_evidence",
        "grade_evidence_strength",
        "create_decision_source_pack",
        "map_source_disagreement",
        "quote_or_paraphrase_safely",
